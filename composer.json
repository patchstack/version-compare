{
    "name": "patchstack/version-compare",
    "description": "Framework-agnostic version comparison logic for vulnerability checking",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "pestphp/pest": "^2.0|^3.0"
    },
    "autoload": {
        "psr-4": {
            "Patchstack\\VersionCompare\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Patchstack\\VersionCompare\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "scripts": {
        "test": "pest"
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
